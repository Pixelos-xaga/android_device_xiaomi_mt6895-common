# One-time OTA migration: clear IMS app data to avoid boot crash loops from older builds.
on post-fs-data
    exec u:r:vendor_init:s0 root root -- /system/bin/sh -c "MARKER=/metadata/ota/ims_data_cleanup_v1_done; if [ ! -f $MARKER ]; then rm -rf /data/user_de/0/com.mediatek.ims /data/user/0/com.mediatek.ims /data/data/com.mediatek.ims /data/user_de/0/com.mediatek.ims.rcs /data/user/0/com.mediatek.ims.rcs /data/data/com.mediatek.ims.rcs /data/user_de/0/com.mediatek.imsservice /data/user/0/com.mediatek.imsservice /data/data/com.mediatek.imsservice; mkdir -p /metadata/ota; touch $MARKER; fi"
